# Marwa Chatbot — Environment Variables
# Copy to .env and fill in the values

# Supabase (marwa-shop project)
SUPABASE_URL=https://icffarzfmegvhhpecoyr.supabase.co
SUPABASE_ANON_KEY=sb_publishable_030nwMaLSosXW0B8nRlUMQ_xye82rNV
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Ollama (local LLM for intent classification)
OLLAMA_BASE_URL=http://redveil-mac.local:11434
OLLAMA_MODEL=qwen3.6:latest

# Telegram Bot
# Create a bot via @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Shop Owner — the auth.uid() of the shop owner in Supabase
# Find this in Supabase Dashboard → Authentication → Users
SHOP_OWNER_ID=YOUR_OWNER_USER_ID_HERE

# Chatbot API (for web widget)
# Set this in marwa-app's .env as VITE_CHATBOT_URL
# VITE_CHATBOT_URL=http://localhost:8000
