# Marwa Chatbot — Environment Variables
# Copy to .env and fill in the values

# Supabase (marwaautorepair project)
SUPABASE_URL=https://gzozhaofzbfdlzysercx.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Ollama (local LLM for intent classification)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6:latest

# Telegram Bot
# Create a bot via @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Shop Owner — the auth.uid() of the shop owner in Supabase
# Find this in Supabase Dashboard → Authentication → Users
SHOP_OWNER_ID=YOUR_OWNER_USER_ID_HERE

# CORS — allowed origins for browser requests (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin API Key — protects /reminders/send and other admin endpoints
ADMIN_API_KEY=YOUR_ADMIN_API_KEY_HERE

# Telegram Webhook Secret — validates incoming webhook requests
TELEGRAM_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# Chatbot API (for web widget)
# Set this in marwa-app's .env as VITE_CHATBOT_URL
# VITE_CHATBOT_URL=http://localhost:8000
